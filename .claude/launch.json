{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static File Server (Python)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "Live Server (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", "--port=3000", "--no-browser"],
      "port": 3000
    }
  ]
}
